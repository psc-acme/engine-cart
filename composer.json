{
    "name": "psc-acme/engine-cart",
    "description": "Package engine-cart for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\EngineCart\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "psr/http-message": "^2.0",
        "symfony/serializer": "^7.0",
        "symfony/console": "^7.0",
        "doctrine/orm": "^3.0",
        "psr/log": "^3.0",
        "psc-acme/lib-cart": "^1.0",
        "psc-acme/registry-cart": "^1.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "rector/rector": "^1.0"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}